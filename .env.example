# heartbeat-iot — Environment variables template
# Copy to .env and fill in your values. NEVER commit .env to git.

# Network
ZEROTIER_NETWORK_ID=your_network_id_here
COORDINATOR_IP=10.147.17.X

# Coordinator
BIND_ADDR=0.0.0.0:9000
HEARTBEAT_TIMEOUT_S=10
ANOMALY_THRESHOLD=38.0

# Edge
RECONNECT_BASE_MS=500

# Sensor
PUBLISH_INTERVAL_MS=500
TEMP_MIN=15.0
TEMP_MAX=40.0
